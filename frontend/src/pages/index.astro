---
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Todo App</title>
  </head>
  <body class="min-h-screen bg-[#f4f4f6] px-4 py-12 font-sans text-zinc-950 sm:px-8 lg:py-16">
    <main class="mx-auto w-full max-w-7xl rounded-2xl bg-white px-5 py-10 shadow-[0_5px_10px_rgba(0,0,0,0.13)] sm:px-12 sm:py-12">
      <h1 class="text-center text-4xl font-bold tracking-tight sm:text-5xl">Todo App</h1>

      <form id="add-form" class="mt-12 flex flex-col gap-3 sm:flex-row sm:gap-4">
        <label class="sr-only" for="new-task">New todo</label>
        <input id="new-task" name="task" type="text" placeholder="Add a new todo" autocomplete="off" class="h-20 min-w-0 flex-1 rounded-xl border-2 border-zinc-200 px-5 text-xl outline-none transition placeholder:text-zinc-500 focus:border-zinc-500" />
        <button type="submit" class="h-20 rounded-xl bg-zinc-900 px-8 text-xl font-semibold text-white transition hover:bg-zinc-700 focus:outline-2 focus:outline-offset-2 focus:outline-zinc-900">Add Todo</button>
      </form>

      <p id="message" class="mt-4 min-h-6 text-sm text-red-600" role="status" aria-live="polite"></p>
      <ul id="todo-list" class="mt-2 space-y-8" aria-label="Todo list"></ul>
    </main>

    <template id="edit-icon"><svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" class="h-7 w-7"><path d="M12 20h9" /><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z" /></svg></template>
    <template id="delete-icon"><svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" class="h-7 w-7"><path d="M3 6h18M8 6V4h8v2m-9 0 1 14h8l1-14M10 11v5m4-5v5" /></svg></template>
  </body>
</html>

<script>
  type Todo = { id: number; task: string; done: boolean };

  const API_URL = "http://localhost:3001/todos";
  const list = document.querySelector<HTMLUListElement>("#todo-list")!;
  const addForm = document.querySelector<HTMLFormElement>("#add-form")!;
  const newTaskInput = document.querySelector<HTMLInputElement>("#new-task")!;
  const message = document.querySelector<HTMLParagraphElement>("#message")!;
  const editIcon = document.querySelector<HTMLTemplateElement>("#edit-icon")!;
  const deleteIcon = document.querySelector<HTMLTemplateElement>("#delete-icon")!;
  let todos: Todo[] = [];
  let editingId: number | null = null;

  const setMessage = (text = "") => (message.textContent = text);
  const getId = (template: HTMLTemplateElement) => template.content.cloneNode(true);
  const itemClass = "flex min-h-32 items-center rounded-xl bg-[#f8f8f9] px-5 py-5 sm:px-6";
  const actionClass = "grid h-20 w-20 place-items-center rounded-xl border-2 border-zinc-200 bg-white text-zinc-950 transition hover:bg-zinc-100 focus:outline-2 focus:outline-offset-2 focus:outline-zinc-900";

  const request = async (path = "", options?: RequestInit) => {
    const response = await fetch(`${API_URL}${path}`, { headers: { "Content-Type": "application/json" }, ...options });
    if (!response.ok) throw new Error("The request failed. Check that the backend is running.");
    return response.status === 204 ? null : response.json();
  };

  const updateTodo = async (id: number, update: Partial<Pick<Todo, "task" | "done">>) => {
    try {
      setMessage();
      const updated = await request(`/${id}`, { method: "PUT", body: JSON.stringify(update) });
      todos = todos.map((todo) => (todo.id === id ? updated : todo));
      editingId = null;
      renderTodos();
    } catch (error) {
      setMessage(error instanceof Error ? error.message : "Unable to update the todo.");
    }
  };

  const deleteTodo = async (id: number) => {
    try {
      setMessage();
      await request(`/${id}`, { method: "DELETE" });
      todos = todos.filter((todo) => todo.id !== id);
      renderTodos();
    } catch (error) {
      setMessage(error instanceof Error ? error.message : "Unable to delete the todo.");
    }
  };

  const renderTodos = () => {
    list.replaceChildren();
    todos.forEach((todo) => {
      const item = document.createElement("li");
      item.className = itemClass;

      if (editingId === todo.id) {
        const form = document.createElement("form");
        form.className = "flex w-full flex-col gap-3 sm:flex-row";
        const input = document.createElement("input");
        input.value = todo.task;
        input.className = "h-20 min-w-0 flex-1 rounded-xl border-2 border-zinc-300 bg-white px-5 text-xl outline-none ring-4 ring-zinc-400/60 focus:border-zinc-500";
        input.setAttribute("aria-label", "Edit todo");
        const save = document.createElement("button");
        save.type = "submit";
        save.textContent = "Save";
        save.className = "h-20 rounded-xl bg-zinc-900 px-7 text-xl font-semibold text-white hover:bg-zinc-700";
        const cancel = document.createElement("button");
        cancel.type = "button";
        cancel.textContent = "Cancel";
        cancel.className = "h-20 rounded-xl px-5 text-base font-medium text-zinc-600 hover:bg-zinc-200";
        cancel.addEventListener("click", () => { editingId = null; renderTodos(); });
        form.addEventListener("submit", (event) => { event.preventDefault(); if (input.value.trim()) updateTodo(todo.id, { task: input.value.trim() }); });
        form.append(input, save, cancel);
        item.append(form);
        list.append(item);
        input.focus();
        return;
      }

      const label = document.createElement("label");
      label.className = "flex min-w-0 flex-1 cursor-pointer items-center gap-4 text-xl sm:text-3xl";
      const checkbox = document.createElement("input");
      checkbox.type = "checkbox";
      checkbox.checked = todo.done;
      checkbox.className = "h-8 w-8 shrink-0 accent-zinc-900";
      checkbox.addEventListener("change", () => updateTodo(todo.id, { done: checkbox.checked }));
      const text = document.createElement("span");
      text.textContent = todo.task;
      text.className = todo.done ? "truncate text-zinc-500 line-through" : "truncate";
      label.append(checkbox, text);

      const actions = document.createElement("div");
      actions.className = "ml-4 flex shrink-0 gap-3";
      const edit = document.createElement("button");
      edit.type = "button";
      edit.className = actionClass;
      edit.setAttribute("aria-label", "Edit todo");
      edit.append(getId(editIcon));
      edit.addEventListener("click", () => { editingId = todo.id; renderTodos(); });
      const remove = document.createElement("button");
      remove.type = "button";
      remove.className = actionClass;
      remove.setAttribute("aria-label", "Delete todo");
      remove.append(getId(deleteIcon));
      remove.addEventListener("click", () => deleteTodo(todo.id));
      actions.append(edit, remove);
      item.append(label, actions);
      list.append(item);
    });
  };

  addForm.addEventListener("submit", async (event) => {
    event.preventDefault();
    const task = newTaskInput.value.trim();
    if (!task) return;
    try {
      setMessage();
      const todo = await request("", { method: "POST", body: JSON.stringify({ task }) });
      todos.unshift(todo);
      newTaskInput.value = "";
      renderTodos();
    } catch (error) {
      setMessage(error instanceof Error ? error.message : "Unable to add the todo.");
    }
  });

  request().then((data) => { todos = data; renderTodos(); }).catch((error) => setMessage(error instanceof Error ? error.message : "Unable to load todos."));
</script>
